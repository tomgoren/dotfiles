{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.2-codex",
  "disabled_providers": [
    "opencode"
  ],
  // Pro mode points OPENCODE_CONFIG at this file, so shared MCP entries must be kept here too.
  "mcp": {
    "plane": {
      "type": "local",
      "enabled": true,
      "command": ["uvx", "--with", "fakeredis<2.35", "plane-mcp-server", "stdio"],
      "environment": {
        "PLANE_API_KEY": "{env:PLANE_API_KEY}",
        "PLANE_WORKSPACE_SLUG": "{env:PLANE_WORKSPACE_SLUG}",
        "PLANE_BASE_URL": "{env:PLANE_BASE_URL}"
      }
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.5"
    },
    "plan": {
      "model": "openai/gpt-5.5"
    },
    "explore": {
      "model": "openai/gpt-5.2"
    },
    "compaction": {
      "model": "openai/gpt-5.2-codex"
    },
    "title": {
      "model": "openai/gpt-5.2"
    },
    "draft": {
      "model": "openai/gpt-5.2-codex"
    },
    "review": {
      "model": "openai/gpt-5.2"
    }
  }
}
